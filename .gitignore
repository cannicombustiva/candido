.DS_Store
.build/
.swiftpm/
DerivedData/
# Generated by xcodegen from project.yml — project.yml is the source of truth
JobTracker.xcodeproj/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist

# Real application data. The JSON backup mirror holds company names, titles and
# private notes; this repo is public. Never let an export be committed, wherever
# the backup folder happens to point.
jobtracker-backup*.json
/*.json
!/skills-lock.json

# Scratch space for local-markdown notes and throwaway prototypes
.scratch/
